// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum PostTheme {
  HERO
  EM_DESTAQUE
  PARA_REFLEXAO
  NOSSA_SAUDE
  SOBRE_RELACIONAMENTOS
  EMPRESAS_NEGOCIOS
  ESTETICA_BELEZA
  RINDO_A_TOA
  QUEBRA_CUCA
  GASTRONOMIA
  SUPER_DICAS
}

enum PostPosition {
  LEFT
  CENTER
  RIGHT
  MAIN
  SIDE
}

enum AdPosition {
  HERO_BOTTOM
  BUSINESS_BANNER_1
  NOSSA_SAUDE_RIGHT
  SOBRE_RELACIONAMENTOS_MIDDLE
  PROMOTIONAL_BANNER_1
  EMPRESAS_NEGOCIOS_RIGHT
  RINDO_A_TOA_MIDDLE
  BUILD_BUSINESS_BANNER
  GASTRONOMIA_BOTTOM
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password_hash String
  avatar        String? // URL da imagem do avatar
  role          Role      @default(MEMBER)
  created_at    DateTime  @default(now())
  Post          Post[]
  Comment       Comment[]

  @@map("users")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relacionamento com posts
  posts Post[]

  @@index([slug])
  @@map("categories")
}

model Post {
  id             String    @id @default(uuid())
  title          String
  slug           String    @unique
  excerpt        String?
  content        String
  featured_image String?
  published      Boolean   @default(false)
  published_at   DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  // Relacionamentos
  author          User          @relation(fields: [author_id], references: [id])
  author_id       String
  category        Category      @relation(fields: [category_id], references: [id])
  category_id     String
  professional    Professional? @relation(fields: [professional_id], references: [id])
  professional_id String?
  comments        Comment[]
  tags            TagsOnPosts[]
  views           ViewLog[]
  homeSlots       HomeSlot[]

  @@index([slug])
  @@index([author_id])
  @@index([category_id])
  @@index([professional_id])
  @@index([published, published_at])
  @@index([theme, position, order])
  @@map("posts")
}

model Comment {
  id          String   @id @default(uuid())
  content     String
  is_approved Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relacionamentos
  post      Post   @relation(fields: [post_id], references: [id], onDelete: Cascade)
  post_id   String
  author    User   @relation(fields: [author_id], references: [id])
  author_id String

  // Auto-relacionamento para comentários aninhados
  parent_id String?
  parent    Comment?  @relation("CommentToComment", fields: [parent_id], references: [id])
  replies   Comment[] @relation("CommentToComment")

  @@index([post_id])
  @@index([author_id])
  @@index([parent_id])
  @@map("comments")
}

model Tag {
  id         String   @id @default(uuid())
  name       String   @unique
  slug       String   @unique
  color      String   @default("")
  created_at DateTime @default(now())

  // Relacionamento com posts
  posts TagsOnPosts[]

  @@index([slug])
  @@map("tags")
}

model TagsOnPosts {
  // Relacionamento muitos-para-muitos
  post       Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)
  post_id    String
  tag        Tag      @relation(fields: [tag_id], references: [id], onDelete: Cascade)
  tag_id     String
  created_at DateTime @default(now())

  @@id([post_id, tag_id])
  @@map("posts_tags")
}

model ViewLog {
  id         String   @id @default(uuid())
  ip_address String?
  user_agent String?
  referer    String?
  created_at DateTime @default(now())

  // Relacionamento com post
  post    Post   @relation(fields: [post_id], references: [id], onDelete: Cascade)
  post_id String

  @@index([post_id])
  @@index([created_at])
  @@map("view_logs")
}

model Upload {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  mimetype     String
  size         Int
  url          String
  type         String // "user" ou "post"
  entityId     String? // ID do usuário ou post
  created_at   DateTime @default(now())

  @@index([entityId])
  @@index([type])
  @@map("uploads")
}

model SiteSettings {
  id               String   @id @default(uuid())
  site_name        String   @default("Blog Loctor")
  site_description String?  @db.Text
  primary_color    String   @default("#2563eb")
  secondary_color  String   @default("#1e40af")
  accent_color     String   @default("#f59e0b")
  logo_url         String?
  favicon_url      String?
  hero_title       String?  @db.Text
  hero_subtitle    String?  @db.Text
  footer_text      String?  @db.Text
  contact_email    String?
  contact_phone    String?
  social_facebook  String?
  social_instagram String?
  social_linkedin  String?
  social_twitter   String?
  google_analytics String?
  meta_keywords    String?  @db.Text
  meta_description String?  @db.Text
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("site_settings")
}

model Ad {
  id         String     @id @default(uuid())
  title      String
  image_url  String
  link_url   String?    @default("#")
  position   AdPosition
  active     Boolean    @default(true)
  order      Int        @default(0)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  @@index([position, active])
  @@map("ads")
}

model HomeSlot {
  id         String   @id @default(uuid())
  section    String // HERO, EM_DESTAQUE, PARA_REFLEXAO, etc
  position   String // MAIN, LEFT, CENTER, RIGHT, SIDE, SLOT_1, SLOT_2, etc
  slot_index Int? // Para carousels e grids (0, 1, 2, ...)
  order      Int      @default(0)
  post_id    String? // Post associado a este slot
  post       Post?    @relation(fields: [post_id], references: [id], onDelete: SetNull)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([section, position, slot_index])
  @@index([post_id])
  @@map("home_slots")
}

model Professional {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  title            String // Ex: "Dentista", "Médico", etc
  specialty        String // Especialidade principal
  register         String?
  bio              String   @db.Text
  avatar           String?
  cover_image      String?
  email            String
  phone            String
  address          String
  city             String?
  state            String?
  additional_cities Json?    // Array de cidades adicionais onde o profissional atua: [{city, state}]
  working_hours    String?
  specialties      Json? // Array de especialidades
  services         Json? // Array de serviços
  testimonials     Json? // Array de depoimentos
  faqs             Json? // Array de perguntas frequentes
  gallery_images   Json? // Array de URLs de imagens da galeria
  
  // Seção "Dores do Cliente" (VOCÊ ENFRENTA ALGUM DESTES PROBLEMAS?)
  pain_points_title    String?  // Título da seção (ex: "VOCÊ ENFRENTA ALGUM DESTES PROBLEMAS?")
  pain_points_subtitle String?  @db.Text // Subtítulo/descrição da seção
  pain_points_image    String?  // URL da imagem da seção
  pain_points          Json?    // Array de dores: [{id, title, description}]
  
  // Seção de Serviços (aparece após SOBRE com imagem e lista de serviços)
  services_section_title    String?  // Título da seção de serviços
  services_section_subtitle String?  @db.Text // Subtítulo da seção de serviços
  
  social_facebook  String?
  social_instagram String?
  social_linkedin  String?
  social_twitter   String?
  social_youtube   String?
  social_whatsapp  String?
  active           Boolean  @default(true)
  featured         Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relacionamentos
  posts Post[]

  @@index([slug])
  @@index([active])
  @@index([featured])
  @@index([city, state])
  @@map("professionals")
}
